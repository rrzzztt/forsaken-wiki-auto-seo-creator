# This is the name of the character. Can be used as 'CHARACTERNAME' in the 'keywords' variable.
name=Shedletsky
# This the keywords that are going to be used. Seperate keywords with ',' and use 'SKINNAME' for writing the skin's name and 'CHARACTERNAME' in order to write the character's name.
keywords=forsaken,wiki,CHARACTERNAME,SKINNAME
# This is the skintag that appears right after 'Skin'. Eg. 'SkinShed', in this case 'Shed' is the skintag.
skintag=Shed
# Do not change this value. This variable is the variable that the program uses to check if the config file is up to date.
version=3
